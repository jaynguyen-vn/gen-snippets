        <item>
            <title>2.10.4</title>
            <pubDate>Wed, 01 Jul 2026 17:24:38 +0700</pubDate>
            <sparkle:version>24</sparkle:version>
            <sparkle:shortVersionString>2.10.4</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>11.5</sparkle:minimumSystemVersion>
            <description><![CDATA[<ul><li>Further fix for snippets occasionally pasting recently-copied clipboard content instead of the snippet: the app now waits for the clipboard write to settle before pasting and holds the snippet on the clipboard long enough for the target app to read it before restoring your previous clipboard</li></ul>]]></description>
            <enclosure url="https://github.com/jaynguyen-vn/gen-snippets/releases/download/v2.10.4/GenSnippets.2.10.4.dmg" length="2740259" type="application/octet-stream" sparkle:edSignature="IZ3LempsgxKC553yQgjpe1qskA4u6Yjr02q+MPNPYb15m00VGqi3CCDmz47LxMiFHY+pRCHjL1QykFTHfuHfCg=="/>
